SECRET_KEY=tu_clave_secreta_aqui_cambiar

# Base de datos
# Para desarrollo con SQLite (no recomendado en producción)
# DATABASE_URL=sqlite:///inventapro.db

# Para producción con PostgreSQL en Render
# DATABASE_URL=postgresql://usuario:password@host:5432/nombre_base_datos

# En Render, la URL de base de datos se proporciona automáticamente
# Solo necesitas copiarla desde el servicio PostgreSQL que crees
